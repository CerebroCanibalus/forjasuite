{
  "name": "@CerebroCanibalus/forjasuite",
  "version": "1.3.0",
  "description": "Forja-Suite — Context Engineering toolkit for OpenCode: universal file reader, project scanner, skill manager, batch refactor/build, reminders, and surgical security guards.",
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src/",
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "opencode-plugin",
    "file-reader",
    "project-scanner",
    "skill-manager",
    "batch-refactor",
    "code-quality",
    "reminders",
    "context-engineering"
  ],
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/CerebroCanibalus/forjasuite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CerebroCanibalus/forjasuite.git",
    "directory": "/"
  },
  "bugs": {
    "url": "https://github.com/CerebroCanibalus/forjasuite/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "public"
  },
  "opencode": {
    "title": "Forja-Suite",
    "icon": "hammer"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --target=es2022 --platform=node --outfile=dist/plugin.js --external:zod --external:@opencode-ai/plugin",
    "watch": "esbuild src/index.ts --bundle --target=es2022 --platform=node --outfile=dist/plugin.js --external:zod --external:@opencode-ai/plugin --watch",
    "bundle-size": "esbuild src/index.ts --bundle --target=es2022 --platform=node --outfile=dist/plugin.js --external:zod --external:@opencode-ai/plugin --metafile=dist/meta.json && esbuild --analyze=dist/meta.json",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run check && npm run build"
  }
}
